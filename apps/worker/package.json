{
  "name": "@caffecode/worker",
  "private": true,
  "version": "0.0.1",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./workers/push.logic": "./dist/workers/push.logic.js",
    "./repositories/push.repository": "./dist/repositories/push.repository.js",
    "./channels/telegram": "./dist/channels/telegram.js",
    "./channels/line": "./dist/channels/line.js",
    "./channels/email": "./dist/channels/email.js",
    "./channels/interface": "./dist/channels/interface.js"
  },
  "typesVersions": {
    "*": {
      "workers/push.logic": ["dist/workers/push.logic.d.ts"],
      "repositories/push.repository": ["dist/repositories/push.repository.d.ts"],
      "channels/telegram": ["dist/channels/telegram.d.ts"],
      "channels/line": ["dist/channels/line.d.ts"],
      "channels/email": ["dist/channels/email.d.ts"],
      "channels/interface": ["dist/channels/interface.d.ts"]
    }
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--require=../../scripts/ipv4-only.cjs' tsx watch --env-file .env src/index.ts",
    "postinstall": "tsc || true",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@caffecode/shared": "workspace:*",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@supabase/supabase-js": "^2.97.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  }
}
