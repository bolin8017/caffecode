# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram Bot (required for Telegram connect + webhook)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
# Secret token set via Telegram setWebhook — must match what Telegram sends
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# Site URL (used by sitemap.ts and push notifications)
NEXT_PUBLIC_SITE_URL=https://caffecode.net

# LINE Bot (required for LINE connect + webhook + push)
# Get from: https://developers.line.biz/ → Messaging API channel
LINE_CHANNEL_ACCESS_TOKEN=your-long-lived-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret
LINE_BOT_BASIC_ID=@your_bot_basic_id

# Sentry (optional — enables error tracking)
SENTRY_DSN=

# PostHog (optional — enables analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
