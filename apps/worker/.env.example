# Supabase (required — service_role key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram Bot (required for push delivery)
TELEGRAM_BOT_TOKEN=your-bot-token

# LINE Bot (required for LINE push delivery)
LINE_CHANNEL_ACCESS_TOKEN=your-long-lived-channel-access-token

# App URL (used in push message links)
APP_URL=https://caffecode.net

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=CaffeCode <noreply@caffecode.net>

# Sentry (optional — enables error tracking)
SENTRY_DSN=
