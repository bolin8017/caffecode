{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "app/**",
        "lib/**",
        "components/**",
        "public/**",
        "package.json",
        "tsconfig.json",
        "next.config.ts",
        "postcss.config.mjs",
        "instrumentation.ts",
        "proxy.ts"
      ],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "TELEGRAM_BOT_TOKEN",
        "TELEGRAM_BOT_USERNAME",
        "TELEGRAM_WEBHOOK_SECRET",
        "NEXT_PUBLIC_SITE_URL",
        "LINE_CHANNEL_ACCESS_TOKEN",
        "LINE_CHANNEL_SECRET",
        "LINE_BOT_BASIC_ID",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "SENTRY_DSN",
        "NEXT_PUBLIC_POSTHOG_KEY",
        "NEXT_PUBLIC_POSTHOG_HOST",
        "CRON_SECRET",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "KV_REST_API_URL",
        "KV_REST_API_TOKEN",
        "PUSH_SELECT_CONCURRENCY",
        "PUSH_DISPATCH_CONCURRENCY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "lib/**", "app/**", "__tests__/**", "e2e/**", "vitest.config.ts", "package.json", "tsconfig.json"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "lib/**", "app/**", "__tests__/**", "vitest.config.ts", "package.json", "tsconfig.json"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "inputs": ["src/**", "lib/**", "app/**", "eslint.config.mjs", "package.json", "tsconfig.json"]
    }
  }
}
